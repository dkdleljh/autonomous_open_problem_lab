{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aopl.local/schemas/normalized_problem_schema.json",
  "title": "NormalizedProblem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "problem_id",
    "title",
    "domain",
    "objects",
    "assumptions",
    "target",
    "equivalent_forms",
    "weak_forms",
    "strong_forms",
    "notation_map",
    "source_problem"
  ],
  "properties": {
    "problem_id": {
      "type": "string",
      "pattern": "^prob_[\\w가-힣]+$"
    },
    "title": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target": {
      "type": "string"
    },
    "equivalent_forms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "weak_forms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strong_forms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notation_map": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "source_problem": {
      "type": "object"
    }
  }
}
