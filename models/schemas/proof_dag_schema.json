{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aopl.local/schemas/proof_dag_schema.json",
  "title": "ProofDAG",
  "type": "object",
  "additionalProperties": false,
  "required": ["problem_id", "backend", "root_node", "target_node", "nodes", "edges"],
  "properties": {
    "problem_id": {
      "type": "string",
      "pattern": "^prob_[\\w가-힣]+$"
    },
    "backend": {
      "type": "string",
      "enum": ["demo", "real", "unknown"]
    },
    "root_node": {
      "type": "string"
    },
    "target_node": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node_id", "node_type", "title", "statement", "dependencies", "status"],
        "properties": {
          "node_id": {
            "type": "string"
          },
          "node_type": {
            "type": "string",
            "enum": ["definition", "lemma", "theorem", "claim", "invariant", "reduction"]
          },
          "title": {
            "type": "string"
          },
          "statement": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
